<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-body">

            <h3 class="mb-4">
                Chỉnh sửa bài viết
            </h3>

            <form
                action="/courses/{{course._id}}?_method=PUT"
                method="POST"
            >

                <!-- Tiêu đề -->
                <div class="mb-3">

                    <label
                        for="name"
                        class="form-label"
                    >
                        Tiêu đề bài viết
                    </label>

                    <input
                        type="text"
                        class="form-control"
                        id="name"
                        name="name"
                        value="{{course.name}}"
                        required
                    >
                </div>

                <!-- Mô tả -->
                <div class="mb-3">

                    <label
                        for="description"
                        class="form-label"
                    >
                        Mô tả ngắn
                    </label>

                    <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="3"
                    >{{course.description}}</textarea>

                </div>

                <!-- Thumbnail -->
                <div class="mb-3">

                    <label
                        for="image"
                        class="form-label"
                    >
                        Link ảnh thumbnail
                    </label>

                    <input
                        type="text"
                        class="form-control"
                        id="image"
                        name="image"
                        value="{{course.image}}"
                    >
                </div>

                <!-- Nội dung -->
                <div class="mb-3">

                    <label
                        for="content"
                        class="form-label"
                    >
                        Nội dung bài viết
                    </label>

                    <textarea
                        class="form-control"
                        id="content"
                        name="content"
                        rows="8"
                    >{{course.content}}</textarea>

                </div>

                <!-- Danh mục -->
                <div class="mb-3">

                    <label
                        for="category"
                        class="form-label"
                    >
                        Danh mục
                    </label>

                    <select
                        class="form-select"
                        id="category"
                        name="category"
                    >

                        <option
                            value="Tin tức"
                        >
                            Tin tức
                        </option>

                        <option
                            value="Thông báo"
                        >
                            Thông báo
                        </option>

                        <option
                            value="Sự kiện"
                        >
                            Sự kiện
                        </option>

                    </select>
                </div>

                <!-- Trạng thái -->
                <div class="mb-4">

                    <label
                        for="status"
                        class="form-label"
                    >
                        Trạng thái
                    </label>

                    <select
                        class="form-select"
                        id="status"
                        name="status"
                    >

                        <option
                            value="published"
                        >
                            Công khai
                        </option>

                        <option
                            value="draft"
                        >
                            Nháp
                        </option>

                    </select>
                </div>

                <button
                    type="submit"
                    class="btn btn-primary"
                >
                    Lưu thay đổi
                </button>

            </form>

        </div>
    </div>

</div>