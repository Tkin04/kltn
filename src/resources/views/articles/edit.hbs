<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-body">

            <h3 class="mb-4">
                Chỉnh sửa bài viết
            </h3>

            <form
                id="editArticleForm"
                action="/articles/{{article._id}}?_method=PUT&page={{page}}"
                method="POST"
                enctype="multipart/form-data"
            >

                <!-- Tiêu đề -->
                <div class="mb-3">
                    <label for="name" class="form-label" > Tiêu đề bài viết </label>

                    <input
                        type="text"
                        class="form-control"
                        minlength="5"
                        maxlength="150"
                        id="name"
                        name="name"
                        value="{{article.name}}"
                        required
                    >
                </div>

                <!-- Mô tả -->
                <div class="mb-3">
                    <label for="description" class="form-label" >
                        Mô tả ngắn
                    </label>

                    <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="3"
                        minlength="10"
                        maxlength="300"
                    >{{{article.description}}}</textarea>

                </div>

                <!-- Thumbnail -->
                <div class="mb-3">
                    <label for="image" class="form-label" > Thumbnail bài viết </label>

                    <img
                        id="thumbnail-preview"
                        src="{{article.image}}"
                        alt="{{article.name}}"
                        style="
                            max-width:300px;
                            display:block;
                            margin-bottom:10px;
                            border-radius:8px;
                        "
                    >

                    <input
                        type="file"
                        name="image"
                        class="form-control"
                        accept="image/*"
                    >

                </div>

                <!-- Nội dung -->
                <div class="mb-3">
                    <label for="content" class="form-label" > Nội dung bài viết </label>

                    <textarea
                        id="content"
                        name="content"
                    >{{{article.content}}}</textarea>

                </div>

                <!-- Danh mục -->
                <div class="mb-3">
                    <label for="category" class="form-label" > Danh mục </label>

                    <select class="form-select" id="category" name="category" >
                        <option value="general"> Tin tức chung </option>
                        <option value="transfer"> Chuyển nhượng </option>
                        <option value="premier-league"> Ngoại hạng Anh </option>
                        <option value="champions-league"> Champions League </option>
                        <option value="laliga"> La Liga </option>
                        <option value="serie-a"> Serie A </option>
                        <option value="bundesliga"> Bundesliga </option>
                    </select>

                </div>

                <!-- Trạng thái -->
                <div class="mb-4">
                    <label for="status" class="form-label" > Trạng thái </label>

                    <select
                        class="form-select"
                        id="status"
                        name="status"
                    >
                        <option value="published" > Công khai </option>
                        <option value="draft" > Nháp </option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" > Lưu thay đổi </button>
            </form>

        </div>
    </div>

</div>
<script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

<script>
document.addEventListener(
    'DOMContentLoaded',
    function () {

        let editor;
        let isDirty = false;

        const markDirty = () => {
            isDirty = true;
        };

        // Thumbnail preview
        const imageInput =
            document.querySelector(
                'input[name="image"]'
            );

        const preview =
            document.getElementById(
                'thumbnail-preview'
            );

        if (
            imageInput &&
            preview
        ) {
            imageInput.addEventListener(
                'change',
                function () {

                    const file =
                        this.files[0];

                    if (!file) return;

                    preview.src =
                        URL.createObjectURL(
                            file
                        );

                    preview.style.display =
                        'block';

                    markDirty();
                }
            );
        }

        ClassicEditor.create(
            document.querySelector(
                '#content'
            ),
            {
                toolbar: [
                    'heading',
                    '|',
                    'bold',
                    'italic',
                    '|',
                    'bulletedList',
                    'numberedList',
                    '|',
                    'link',
                    'insertTable',
                    '|',
                    'undo',
                    'redo'
                ],

                heading: {
                    options: [
                        {
                            model:
                                'paragraph',
                            title:
                                'Paragraph',
                            class:
                                'ck-heading_paragraph'
                        },
                        {
                            model:
                                'heading2',
                            view: 'h2',
                            title:
                                'Heading 2',
                            class:
                                'ck-heading_heading2'
                        },
                        {
                            model:
                                'heading3',
                            view: 'h3',
                            title:
                                'Heading 3',
                            class:
                                'ck-heading_heading3'
                        }
                    ]
                },

                simpleUpload: {
                    uploadUrl:
                        '/articles/upload-editor-image'
                }
            }
        )
        .then(newEditor => {

            editor =
                newEditor;

            // Detect CKEditor changes
            editor.model.document.on(
                'change:data',
                markDirty
            );

            // Track form field changes
            [
                'name',
                'description'
            ].forEach(id => {
                document
                    .getElementById(id)
                    ?.addEventListener(
                        'input',
                        markDirty
                    );
            });

            [
                'category',
                'status'
            ].forEach(id => {
                document
                    .getElementById(id)
                    ?.addEventListener(
                        'change',
                        markDirty
                    );
            });

            const statusEl =
                document.getElementById(
                    'status'
                );

            if (statusEl) {
                statusEl
                    .addEventListener(
                        'change',
                        markDirty
                    );
            }

            // Warning before leave
            const handleBeforeUnload = function (e) {

                if (!isDirty) {
                    return;
                }

                e.preventDefault();
                e.returnValue = '';
            };

            window.addEventListener(
                'beforeunload',
                handleBeforeUnload
            );

            // Form validation
            const form =
                document.getElementById(
                    'editArticleForm'
                );
            const submitBtn = form.querySelector(
                'button[type="submit"]'
            );
            if (submitBtn) {
                submitBtn.addEventListener(
                    'click',
                    function () {

                        isSubmitting = true;
                        isDirty = false;

                        window.removeEventListener(
                            'beforeunload',
                            handleBeforeUnload
                        );
                    }
                );
            }
            form.addEventListener(
                'submit',
                function (e) {

                    e.preventDefault();

                    editor.updateSourceElement();

                    const title = document.getElementById( 'name' )
                        .value
                        .trim();
                    const description = document.getElementById( 'description' )
                        .value
                        .trim();
                    const doc = new DOMParser()
                        .parseFromString(
                            editor.getData(),
                            'text/html'
                        );
                    const content = doc.body.textContent
                        .replace(
                            /\u00A0/g,
                            ''
                        )
                        .replace(
                            /\s+/g,
                            ''
                        )
                        .trim();

                    if (!title) {
                        alert( 'Vui lòng nhập tiêu đề' );
                        return;
                    }

                    if ( title.length < 5 ) {
                        alert( 'Tiêu đề phải có ít nhất 5 ký tự' );
                        return;
                    }

                    if (!description) {
                        alert( 'Vui lòng nhập mô tả' );
                        return;
                    }

                    if ( description.length < 10 ) {
                        alert( 'Mô tả ngắn phải có ít nhất 10 ký tự' );
                        return;
                    }

                    if ( content.length === 0 ) {
                        alert( 'Vui lòng nhập nội dung bài viết' );
                        return;
                    }

                    HTMLFormElement
                        .prototype
                        .submit
                        .call(form);
                },
            );

        })
        .catch(error => {
            console.error(error);
        });

    }
);
</script>