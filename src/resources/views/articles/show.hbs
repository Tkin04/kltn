<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <!-- Category -->
            <span class="badge bg-danger mb-3">
                {{#if (eq article.category "transfer")}}
                    Chuyển nhượng
                {{/if}}

                {{#if (eq article.category "premier-league")}}
                    Ngoại hạng Anh
                {{/if}}

                {{#if (eq article.category "champions-league")}}
                    Champions League
                {{/if}}

                {{#if (eq article.category "laliga")}}
                    La Liga
                {{/if}}

                {{#if (eq article.category "serie-a")}}
                    Serie A
                {{/if}}

                {{#if (eq article.category "bundesliga")}}
                    Bundesliga
                {{/if}}

                {{#if (eq article.category "general")}}
                    Tin tức chung
                {{/if}}
            </span>

            <!-- Title -->
            <h1 class=" fw-bold display-5 mb-4 ">
                {{article.name}}
            </h1>

            <!-- Meta -->
            <div class=" d-flex flex-wrap gap-3 text-muted border-bottom pb-3 mb-4 ">
                <span>
                    👁 {{article.views}}
                    lượt xem
                </span>
                <span>
                    📰 Football News
                </span>
                <span>
                    📅
                    {{formatDate article.createdAt}}
                </span>
            </div>
            <!-- Thumbnail -->
            {{#if article.image}}
            <img
                src="{{#if article.image}}{{article.image}}{{else}}/img/default-news.jpg{{/if}}"
                alt="{{article.name}}"
                class="img-fluid rounded-4 shadow-sm mb-5 w-100"
                style="max-height: 500px; object-fit: cover;"
            >
            {{/if}}

            <!-- Description -->
            {{#if article.description}}
            <div class=" bg-light rounded-4 p-4 mb-5 ">
                <h5 class="fw-bold">
                    Tóm tắt
                </h5>
                <p class="mb-0">
                    {{article.description}}
                </p>
            </div>
            {{/if}}

            <!-- Content -->
            <div class=" fs-5 lh-lg mb-5 ">
                {{article.content}}
            </div>

            <!-- Related -->
            {{#if relatedArticles.length}}
            <section class="mt-5">
                <h3 class="fw-bold mb-4">Tin liên quan</h3>
                <div class="row g-4">
                    {{#each relatedArticles}}
                    <div class="col-md-4">
                        <div class=" card h-100 border-0 shadow-sm rounded-4 overflow-hidden ">
                            <a href="/articles/{{this.slug}}">
                                <img
                                    src="{{#if this.image}}{{this.image}}{{else}}/img/default-news.jpg{{/if}}"
                                    class="card-img-top"
                                    alt="{{this.name}}"
                                    style="height: 180px; object-fit: cover;"
                                    onerror="this.src='/img/default-news.jpg'"
                                >
                            </a>
                            <div class="card-body">
                                <span class="badge bg-danger mb-2">
                                    {{#if (eq this.category "transfer")}}
                                        Chuyển nhượng
                                    {{/if}}
                                    {{#if (eq this.category "premier-league")}}
                                        Ngoại hạng Anh
                                    {{/if}}
                                    {{#if (eq this.category "champions-league")}}
                                        Champions League
                                    {{/if}}
                                    {{#if (eq this.category "laliga")}}
                                        La Liga
                                    {{/if}}
                                    {{#if (eq this.category "serie-a")}}
                                        Serie A
                                    {{/if}}
                                    {{#if (eq this.category "bundesliga")}}
                                        Bundesliga
                                    {{/if}}
                                    {{#if (eq this.category "general")}}
                                        Tin tức chung
                                    {{/if}}
                                </span>                                
                                <h6 class=" fw-bold ">
                                    <a
                                        href="/articles/{{this.slug}}"
                                        class=" text-decoration-none text-dark "
                                    >
                                        {{this.name}}
                                    </a>
                                </h6>
                            </div>
                        </div>
                    </div>
                    {{/each}}
                </div>
            </section>
            {{/if}}
        </div>
    </div>
</div>