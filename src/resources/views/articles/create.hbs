<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-body">

            <h3 class="mb-4">
                Tạo bài viết mới
            </h3>

            <form
                action="/articles/store"
                method="POST"
                enctype="multipart/form-data"
                novalidate
            >

                <!-- Tiêu đề -->
                <div class="mb-3">
                    <label for="name" class="form-label" >
                        Tiêu đề bài viết
                    </label>

                    <input
                        type="text"
                        class="form-control"
                        id="name"
                        name="name"
                        placeholder="Nhập tiêu đề..."
                    >
                </div>

                <!-- Mô tả -->
                <div class="mb-3">
                    <label for="description" class="form-label" >
                        Mô tả ngắn
                    </label>

                    <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="3"
                    ></textarea>

                </div>

                <!-- Ảnh -->
                <div class="mb-3">
                    <label for="image" class="form-label" >
                        Link ảnh thumbnail
                    </label>

                    <input
                        type="file"
                        name="image"
                        class="form-control"
                        accept=".jpg,.jpeg,.png,.webp"
                    >
                    <img
                        id="thumbnail-preview"
                        src=""
                        alt="Preview"
                        style="
                            max-width:300px;
                                display:none;
                                margin-top:10px;
                                border-radius:8px;">
                </div>

                <!-- Nội dung -->
                <div class="mb-3">
                    <label for="content" class="form-label" >
                        Nội dung bài viết
                    </label>

                    <textarea
                        class="form-control"
                        id="content"
                        name="content"
                        rows="10"
                    ></textarea>

                </div>

                <!-- Category -->
                <div class="mb-3">
                    <label for="category" class="form-label" >
                        Danh mục
                    </label>

                    <select
                        class="form-select"
                        id="category"
                        name="category"
                    >
                        {{#each categories}}
                        <option value="{{slug}}">
                            {{name}}
                        </option>
                        {{/each}}
                    </select>

                </div>

                <!-- Status -->
                <div class="mb-4">
                    <label for="status" class="form-label" >
                        Trạng thái
                    </label>

                    <select
                        class="form-select"
                        id="status"
                        name="status"
                    >
                        <option value="published" > Công khai </option>
                        <option value="draft" > Nháp </option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" >
                    Đăng bài viết
                </button>

            </form>

        </div>
    </div>

</div>
<script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

<script>
const imageInput = document.querySelector( 'input[name="image"]' );

const preview = document.getElementById( 'thumbnail-preview' );

imageInput.addEventListener( 'change', function () {
    const file = this.files[0];
    if (!file) return;
    preview.src = URL.createObjectURL( file );
    preview.style.display = 'block';
});
</script>

<script>
document.addEventListener( 'DOMContentLoaded', function () {
    let editor;

    const DRAFT_KEY = 'article_create_draft';

    const saveDraft = () => {
        if (!editor) return;
        const title =
            document
                .getElementById('name')
                .value
                .trim();

        const description =
            document
                .getElementById(
                    'description'
                )
                .value
                .trim();

        const content =
            editor
                .getData()
                .replace(/<[^>]*>/g, '')
                .trim();
        if (
            !title &&
            !description &&
            !content
        ) {
            localStorage.removeItem(
                DRAFT_KEY
            );
            return;
        }
        const draft = {
            title,
            description,
            category:
                document.querySelector(
                    'select[name="category"]'
                ).value,
            content:
                editor.getData(),
            updatedAt:
                Date.now()
        };

        localStorage.setItem(
            DRAFT_KEY,
            JSON.stringify(draft)
        );
    };

    ClassicEditor.create(
    document.querySelector( '#content' ),
    {
        toolbar: [
            'heading',
            '|',
            'bold',
            'italic',
            '|',
            'bulletedList',
            'numberedList',
            '|',
            'link',
            'insertTable',
            '|',
            'undo',
            'redo'
        ],

        simpleUpload: {
            uploadUrl:
                '/articles/upload-editor-image'
        }
    }
    )
    .then(newEditor => { 
            editor = newEditor;

            const savedDraft = localStorage.getItem(
                DRAFT_KEY
            );

            if (savedDraft) {

                const shouldRestore =
                    confirm(
                        'Phát hiện bản nháp chưa đăng.\nBạn có muốn khôi phục không?'
                    );

                if (shouldRestore) {

                    const draft =
                        JSON.parse(savedDraft);

                    document
                        .getElementById('name')
                        .value =
                            draft.title || '';

                    document
                        .getElementById(
                            'description'
                        )
                        .value =
                            draft.description || '';

                    const categoryEl =
                        document.querySelector(
                            'select[name="category"]'
                        );

                    if (
                        categoryEl &&
                        draft.category
                    ) {
                        categoryEl.value =
                            draft.category;
                    }

                    if (draft.content) {
                        editor.setData(
                            draft.content
                        );
                    }
                }
            }
            const autoSaveInterval =
                setInterval(
                    saveDraft,
                    2000
                );

            const form = document.querySelector( 'form[action="/articles/store"]' ); 

            form.addEventListener(
                'submit',
                function (e) {
                    e.preventDefault();

                    editor.updateSourceElement();

                    const title = document
                        .getElementById('name')
                        .value
                        .trim();

                    const description = document
                        .getElementById('description')
                        .value
                        .trim();

                    const image = document
                        .querySelector(
                            'input[name="image"]'
                        )
                        .files[0];

                    const rawContent =
                        editor.getData();

                    const parser =
                        new DOMParser();

                    const doc =
                        parser.parseFromString(
                            rawContent,
                            'text/html'
                        );

                    const content =
                        doc.body.textContent
                            .replace(
                                /\u00A0/g,
                                ''
                            )
                            .replace(
                                /\s+/g,
                                ''
                            )
                            .trim();

                    if (!title) {
                        alert(
                            'Vui lòng nhập tiêu đề'
                        );
                        return;
                    }

                    if (title.length < 5) {
                        alert(
                            'Tiêu đề phải có ít nhất 5 ký tự'
                        );
                        return;
                    }

                    if (!description) {
                        alert(
                            'Vui lòng nhập mô tả'
                        );
                        return;
                    }

                    if (
                        description.length < 10
                    ) {
                        alert(
                            'Mô tả ngắn phải có ít nhất 10 ký tự'
                        );
                        return;
                    }

                    if (!image) {
                        alert(
                            'Vui lòng chọn ảnh'
                        );
                        return;
                    }

                    if (
                        content.length === 0
                    ) {
                        alert(
                            'Vui lòng nhập nội dung bài viết'
                        );
                        return;
                    }
                    clearInterval(
                        autoSaveInterval
                    );

                    localStorage.removeItem(
                        DRAFT_KEY
                    );

                    this.submit();
                }
            );

        })
        .catch(error => {
            console.error(error);
        });

    });
</script>


