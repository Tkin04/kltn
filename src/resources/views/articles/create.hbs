<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-body">

            <h3 class="mb-4">
                Tạo bài viết mới
            </h3>

            <form
                action="/articles/store"
                method="POST"
                enctype="multipart/form-data"
                novalidate
            >

                <!-- Tiêu đề -->
                <div class="mb-3">
                    <label for="name" class="form-label" >
                        Tiêu đề bài viết
                    </label>

                    <input
                        type="text"
                        class="form-control"
                        id="name"
                        name="name"
                        placeholder="Nhập tiêu đề..."
                    >
                </div>

                <!-- Mô tả -->
                <div class="mb-3">
                    <label for="description" class="form-label" >
                        Mô tả ngắn
                    </label>

                    <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="3"
                    ></textarea>

                </div>

                <!-- Ảnh -->
                <div class="mb-3">
                    <label for="image" class="form-label" >
                        Link ảnh thumbnail
                    </label>

                    <input
                        type="file"
                        name="image"
                        class="form-control"
                        accept=".jpg,.jpeg,.png,.webp"
                    >
                    <img
                        id="thumbnail-preview"
                        src=""
                        alt="Preview"
                        style="
                            max-width:300px;
                                display:none;
                                margin-top:10px;
                                border-radius:8px;">
                </div>

                <!-- Nội dung -->
                <div class="mb-3">
                    <label for="content" class="form-label" >
                        Nội dung bài viết
                    </label>

                    <textarea
                        class="form-control"
                        id="content"
                        name="content"
                        rows="10"
                    ></textarea>

                </div>

                <!-- Category -->
                <div class="mb-3">
                    <label for="category" class="form-label" >
                        Danh mục
                    </label>

                    <select
                        class="form-select"
                        id="category"
                        name="category"
                    >
                        {{#each categories}}
                        <option value="{{slug}}">
                            {{name}}
                        </option>
                        {{/each}}
                    </select>

                </div>

                <!-- Status -->
                <div class="mb-4">
                    <label for="status" class="form-label" >
                        Trạng thái
                    </label>

                    <select
                        class="form-select"
                        id="status"
                        name="status"
                    >
                        <option value="published" > Công khai </option>
                        <option value="draft" > Nháp </option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" >
                    Đăng bài viết
                </button>

            </form>

        </div>
    </div>

</div>
<link rel="stylesheet" href="/vendor/jodit/jodit.min.css">
<script src="/vendor/jodit/jodit.min.js"></script>
<script src="/js/jodit-google-paste.js"></script>

<script>
const imageInput = document.querySelector( 'input[name="image"]' );

const preview = document.getElementById( 'thumbnail-preview' );

imageInput.addEventListener( 'change', function () {
    const file = this.files[0];
    if (!file) return;
    preview.src = URL.createObjectURL( file );
    preview.style.display = 'block';
});
</script>

<script>
document.addEventListener( 'DOMContentLoaded', function () {
    let editor;

    const DRAFT_KEY = 'article_create_draft';

    const saveDraft = () => {
        if (!editor) return;
        const title =
            document
                .getElementById('name')
                .value
                .trim();

        const description =
            document
                .getElementById(
                    'description'
                )
                .value
                .trim();

        const content =
            editor
                .value
                .replace(/<[^>]*>/g, '')
                .trim();
        if (
            !title &&
            !description &&
            !content
        ) {
            localStorage.removeItem(
                DRAFT_KEY
            );
            return;
        }
        const draft = {
            title,
            description,
            category:
                document.querySelector(
                    'select[name="category"]'
                ).value,
            content:
                editor.value,
            updatedAt:
                Date.now()
        };

        localStorage.setItem(
            DRAFT_KEY,
            JSON.stringify(draft)
        );
    };
    editor = Jodit.make('#content', {
        height: 500,
        toolbarAdaptive: false,

        removeButtons: [
            'file','print','preview','spellcheck','video',
        ],
        uploader: {
            url: '/articles/upload-editor-image',

            isSuccess(resp) {
                return !!resp.url || Array.isArray(resp.files);
            },
            process(resp) {
                if (resp.url) {
                    return {
                        files: [resp.url],
                        isImages: [true],
                        path: '',
                        baseurl: ''
                    };
                }

                return {
                    files: resp.files.map(item => item.url),
                    isImages: resp.files.map(() => true),
                    path: '',
                    baseurl: ''
                };
            },
        }
    });
    attachGooglePaste(editor);

    const savedDraft = localStorage.getItem(
        DRAFT_KEY
    );
    if (savedDraft) {

        const shouldRestore = confirm('Phát hiện bản nháp chưa đăng.\nBạn có muốn khôi phục không?');

        if (shouldRestore) {
            const draft = JSON.parse(savedDraft);

            document
                .getElementById('name')
                .value =
                    draft.title || '';

            document
                .getElementById('description')
                .value = draft.description || '';

            const categoryEl = document.querySelector('select[name="category"]');

            if ( categoryEl && draft.category ) {
                categoryEl.value = draft.category;
            }

            if (draft.content) {
                editor.value = draft.content;
            }
        }
    }
    const autoSaveInterval = setInterval(saveDraft,2000);
    const form = document.querySelector( 'form[action="/articles/store"]' );

    form.addEventListener(
        'submit',
        function (e) {
            e.preventDefault();

            editor.synchronizeValues();

            const title = document
                .getElementById('name')
                .value
                .trim();

            const description = document
                .getElementById('description')
                .value
                .trim();

            const image = document
                .querySelector(
                    'input[name="image"]'
                )
                .files[0];

            const rawContent = editor.value;

            const parser = new DOMParser();

            const doc =
                parser.parseFromString(
                    rawContent,
                    'text/html'
                );

            const content =
                doc.body.textContent
                    .replace(
                        /\u00A0/g,
                        ''
                    )
                    .replace(
                        /\s+/g,
                        ''
                    )
                    .trim();

            if (!title) {
                alert(
                    'Vui lòng nhập tiêu đề'
                );
                return;
            }

            if (title.length < 5) {
                alert(
                    'Tiêu đề phải có ít nhất 5 ký tự'
                );
                return;
            }

            if (!description) {
                alert(
                    'Vui lòng nhập mô tả'
                );
                return;
            }

            if (
                description.length < 10
            ) {
                alert(
                    'Mô tả ngắn phải có ít nhất 10 ký tự'
                );
                return;
            }

            if (!image) {
                alert(
                    'Vui lòng chọn ảnh'
                );
                return;
            }

            if (
                content.length === 0
            ) {
                alert(
                    'Vui lòng nhập nội dung bài viết'
                );
                return;
            }
            clearInterval(
                autoSaveInterval
            );

            localStorage.removeItem(
                DRAFT_KEY
            );

            this.submit();
        }
    );  
});
</script>


