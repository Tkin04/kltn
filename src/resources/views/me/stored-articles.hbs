<form name="container-form" method="POST" action="/articles/handle-form-actions?page={{pagination.page}}" class="mt-4">
    <div>
        <h3>Bài viết đã đăng</h3>
        <a href="/me/trash/articles">Thùng rác ({{deletedCount}})</a>
        <div class="row mt-4 g-3">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Tổng bài viết</h6>
                        <h3 class="fw-bold mb-0">{{analytics.totalArticles}}</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Công khai</h6>
                        <h3 class="fw-bold text-success mb-0">{{analytics.publishedCount}}</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Tin nháp</h6>
                        <h3 class="fw-bold text-warning mb-0">{{analytics.draftCount}}</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Tổng lượt xem</h6>
                        <h3 class="fw-bold text-danger mb-0">{{analytics.totalViews}}</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-4 d-flex align-items-center gap-2 flex-wrap">
            <div class="d-flex align-items-center gap-2">
                <div class="form-check">
                    <input class="form-check-input mt-0" type="checkbox" value="" id="checkbox-all">
                    <label class="form-check-label" for="select-all-checkbox">
                        Chọn tất cả
                    </label>
                </div>

                <select class="form-control form-control-sm checkbox-select-all-options" name="action" required>
                    <option value="">-- Hành động --</option>
                    <option value="delete">Xóa</option>
                </select>

                <button class="btn btn-primary btn-sm check-all-submit-btn disabled">Áp dụng</button>
            </div>

            <form
                method="GET"
                action="/me/stored/articles"
                class="ms-auto d-flex gap-2"
            >
                <input
                    type="text"
                    id="admin-search-input"
                    name="search"
                    class="form-control form-control-sm"
                    placeholder="Tìm tiêu đề bài viết..."
                    style="width:260px;"
                    value="{{search}}"
                >

                <button
                    type="button"
                    id="admin-search-btn"
                    class="btn btn-outline-primary btn-sm"
                >
                    Tìm
                </button>
            </form>
        </div>
    </div>
    <table class="table mt-4">
        <thead>
            <tr>
                <th scope="col"></th>
                <th scope="col">#</th>
                <th scope="col">Tiêu đề {{{sortable 'name' _sort search}}}</th>
                <th scope="col">Danh mục {{{sortable 'category' _sort search}}}</th>
                <th scope="col">Trạng thái {{{sortable 'status' _sort search}}}</th>
                <th scope="col" colspan="2">Ngày đăng {{{sortable 'createdAt' _sort search}}}</th>
            </tr>
        </thead>
        <tbody>
            {{#each articles}}
            <tr>
                <td>
                    <div class="form-check">
                        <input class="form-check-input mt-0" type="checkbox" name="articleIds[]" value="{{this._id}}">
                    </div>
                </td>
                <th scope="row">{{sum
                    ../startIndex
                    (sum @index 1)
                }}</th>
                <td>{{this.name}}</td>
                <td>{{this.category}}</td>
                <td>
                    {{#if (eq this.status 'published')}}
                        Công khai
                    {{else}}
                        Nháp
                    {{/if}}
                </td>
                <td>{{formatDate this.createdAt}}</td>
                <td>
                    <a href="/articles/{{this._id}}/edit?page={{../pagination.page}}" class="btn btn-link">Sửa</a>
                    <a href="" class="btn btn-link" data-bs-toggle="modal" data-id="{{this._id}}"data-page="{{../pagination.page}}" data-bs-target="#confirmDeleteModal">Xóa</a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" class="text-center">Không có bài viết nào.
                    <a href="/articles/create">Đăng ngay.</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{#if articles.length}}
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            {{#if pagination.hasPrev}}
            <li class="page-item">
                <a class="page-link" href="?{{searchQuery}}{{sortQuery}}page={{pagination.prevPage}}">← Trước</a>
            </li>
            {{/if}}
            <li class="page-item active">
                <span class="page-link">
                    {{pagination.page}}
                </span>
            </li>
            {{#if pagination.hasNext}}
            <li class="page-item">
                <a class="page-link" href="?{{searchQuery}}{{sortQuery}}page={{pagination.nextPage}}">Sau →</a>
            </li>
            {{/if}}
        </ul>
    </nav>
    {{/if}}
</form>

{{!-- confirm delete modal --}}
<div id="confirmDeleteModal" class="modal" tabindex="-1" role="dialog">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xác nhận xóa</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Bạn có chắc chắn muốn xóa bài viết này không?</p>
      </div>
      <div class="modal-footer">
        <button id="btn-delete-article" type="button" class="btn btn-danger">Xóa bỏ</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
      </div>
    </div>
  </div>
</div>

{{!-- delete hidden form --}}
<form name="delete-form" method="POST">


<script>
document.addEventListener('DOMContentLoaded', function () {
    var articleId;
    var currentPage;
    var deleteForm = document.forms['delete-form'];
    var containerForm = document.forms['container-form'];
    var btnDeleteArticle = document.getElementById('btn-delete-article');
    var checkboxAll = document.getElementById('checkbox-all');
    var itemCheckboxes = document.querySelectorAll('input[name="articleIds[]"]');
    var checkAllSubmitBtn = document.querySelector('.check-all-submit-btn');

    const modal = document.getElementById('confirmDeleteModal');

    if (modal) {

        // Xử lý sự kiện khi modal được hiển thị
        modal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            articleId = button.getAttribute('data-id');
            currentPage = button.getAttribute('data-page');
        });

        // Xử lý sự kiện click nút "Xóa bỏ" trong modal
        btnDeleteArticle.addEventListener('click', function () {
            deleteForm.action = '/articles/' + articleId + '?_method=DELETE' + '&page=' + currentPage;
            deleteForm.submit();
        });
        // Xử lý sự kiện chọn tất cả checkbox
        checkboxAll.addEventListener('change', function () {
            var isChecked = this.checked;
            itemCheckboxes.forEach(function (checkbox) {
                checkbox.checked = isChecked;
            });
            renderCheckAllSubmitBtn();
        });
        // Cập nhật trạng thái checkbox "Chọn tất cả" khi có sự thay đổi ở các checkbox con
        itemCheckboxes.forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                var total = itemCheckboxes.length;
                var checked = document.querySelectorAll('input[name="articleIds[]"]:checked').length;
                checkboxAll.checked = total === checked;

                renderCheckAllSubmitBtn();
            });
        });
        // Cập nhật trạng thái nút "Áp dụng" khi có sự thay đổi ở các checkbox
        function renderCheckAllSubmitBtn() {
            var checked = document.querySelectorAll('input[name="articleIds[]"]:checked').length;
            checkAllSubmitBtn.classList.toggle('disabled', checked === 0);
        }
    }
    const searchInput =
        document.getElementById(
            'admin-search-input'
        );

    const searchBtn =
        document.getElementById(
            'admin-search-btn'
        );

    console.log(
        'admin input:',
        searchInput
    );

    if (
        searchInput &&
        searchBtn
    ) {
        searchBtn.addEventListener(
            'click',
            function () {

                console.log(
                    'real value:',
                    searchInput.value
                );

                const keyword =
                    searchInput.value
                        .trim();

                console.log(
                    'search keyword:',
                    keyword
                );

                window.location.href =
                    `/me/stored/articles?search=${encodeURIComponent(keyword)}`;
            }
        );
    }
    const searchParams =
        new URLSearchParams(
            window.location.search
        );

    console.log(
        'search query:',
        searchParams.get(
            'search'
        )
    );
});
</script>