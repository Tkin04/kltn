<form class="mt-4" method="POST" action="/articles/handle-form-actions">
    <div>
        <a href="/me/stored/articles">Quay lại</a>
        <h3>Bài viết đã xóa</h3>
        <div class="mt-4 d-flex align-items-center">
            <div class="form-check">
                <input class="form-check-input mt-0" type="checkbox" value="" id="checkbox-all">
                <label class="form-check-label" for="select-all-checkbox">
                    Chọn tất cả
                </label>
            </div>

            <select class="form-control form-control-sm checkbox-select-all-options" name="action" required>
                <option value="">-- Hành động --</option>
                <option value="restore">Khôi phục</option>
                <option value="force-delete">Xóa vĩnh viễn</option>
            </select>

            <button class="btn btn-primary btn-sm check-all-submit-btn disabled">Áp dụng</button>
        </div>
    </div>
    <table class="table mt-4">
        <thead>
            <tr>

                <th scope="col"></th>

                <th scope="col">
                    #
                </th>

                <th scope="col">
                    Tiêu đề
                </th>

                <th scope="col">
                    Danh mục
                </th>

                <th scope="col" colspan="2">
                    Ngày xóa
                </th>

            </tr>
        </thead>
        <tbody>
            {{#each articles}}
            <tr>
                <td>
                    <div class="form-check">
                        <input class="form-check-input mt-0" type="checkbox" name="articleIds[]" value="{{this._id}}">
                    </div>
                </td>
                <th scope="row">{{sum @index 1}}</th>
                <td>{{this.name}}</td>
                <td>{{this.category}}</td>
                <td>{{this.deletedAt}}</td>
                <td>
                    <a href="" class="btn btn-link btn-restore" data-id="{{this._id}}">Khôi phục</a>
                    <a href="" class="btn btn-link" data-bs-toggle="modal" data-id="{{this._id}}" data-bs-target="#confirmDeleteModal">Xóa vĩnh viễn</a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" class="text-center">Thùng rác trống.
                    <a href="/me/stored/articles">Quay lại</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</form>

{{!-- confirm delete modal --}}
<div id="confirmDeleteModal" class="modal" tabindex="-1" role="dialog">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xác nhận xóa</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Hành động này sẽ xóa vĩnh viễn bài viết khỏi cơ sở dữ liệu.
        <br>Bạn có chắc chắn muốn xóa bài viết này không?</p>
      </div>
      <div class="modal-footer">
        <button id="btn-delete-article" type="button" class="btn btn-danger">Xóa bỏ vĩnh viễn</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
      </div>
    </div>
  </div>
</div>

{{!-- delete hidden form --}}
<form name="delete-form" method="POST">
</form>
{{!-- restore hidden form --}}
<form name="restore-form" method="POST">
</form>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var articleId;
    var deleteForm = document.forms['delete-form'];
    var restoreForm = document.forms['restore-form'];
    var btnDeleteArticle = document.getElementById('btn-delete-article');
    var restoreBtn = document.querySelectorAll('.btn-restore');
    var checkboxAll = document.getElementById('checkbox-all');
    var itemCheckboxes = document.querySelectorAll('input[name="articleIds[]"]');
    var checkAllSubmitBtn = document.querySelector('.check-all-submit-btn');

    const modal = document.getElementById('confirmDeleteModal');

    if (modal) {

        
        modal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const id = button.getAttribute('data-id');
            articleId = id;
        });


        btnDeleteArticle.addEventListener('click', function () {
            deleteForm.action = '/articles/' + articleId + '/force?_method=DELETE';
            deleteForm.submit();
        });
    }
    restoreBtn.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();

            const articleId = this.getAttribute('data-id');

            console.log('Restore:', articleId);
            restoreForm.action = '/articles/' + articleId + '/restore?_method=PATCH';
            restoreForm.submit();
        });
    });
    // Xử lý sự kiện chọn tất cả checkbox
        checkboxAll.addEventListener('change', function () {
            var isChecked = this.checked;
            itemCheckboxes.forEach(function (checkbox) {
                checkbox.checked = isChecked;
            });
            renderCheckAllSubmitBtn();
        });
        // Cập nhật trạng thái checkbox "Chọn tất cả" khi có sự thay đổi ở các checkbox con
        itemCheckboxes.forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                var total = itemCheckboxes.length;
                var checked = document.querySelectorAll('input[name="articleIds[]"]:checked').length;
                checkboxAll.checked = total === checked;

                renderCheckAllSubmitBtn();
            });
        });
        // Cập nhật trạng thái nút "Áp dụng" khi có sự thay đổi ở các checkbox
        function renderCheckAllSubmitBtn() {
            var checked = document.querySelectorAll('input[name="articleIds[]"]:checked').length;
            checkAllSubmitBtn.classList.toggle('disabled', checked === 0);
        }
});
</script>