<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow sticky-top">
    <div class="container">

        <!-- Logo -->
        <a class="navbar-brand fw-bold fs-4 text-uppercase" href="/" >
            ⚽ Football News
        </a>

        <!-- Mobile toggle -->
        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarSupportedContent"
        >
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent" >

            <!-- Navigation -->
            <ul class="navbar-nav me-lg-4 flex-nowrap">

                <li class="nav-item">
                    <a class="nav-link {{#unless category}}active{{/unless}}" href="/" >
                        Trang chủ
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{#if (eq category "transfer")}}active{{/if}}" href="/?category=transfer" >
                        Chuyển nhượng
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{#if (eq category "premier-league")}}active{{/if}}" href="/?category=premier-league" >
                        Ngoại hạng Anh
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{#if (eq category "champions-league")}}active{{/if}}" href="/?category=champions-league" >
                        Champions League
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{#if (eq category "laliga")}}active{{/if}}" href="/?category=laliga" >
                        La Liga
                    </a>
                </li>

            </ul>

            <!-- Search -->
            <form
                id="searchForm"
                action="/"
                method="GET"
                class="d-flex my-3 my-lg-0 ms-lg-auto"
                role="search"
            >
                <div class="input-group" style="max-width: 320px;">

                    <input
                        id="headerSearchInput"
                        name="search"
                        class="form-control border-0"
                        type="search"
                        placeholder="Tìm kiếm tin tức bóng đá..."
                        value="{{search}}"
                    >
                    <input
                        id="categoryInput"
                        type="hidden"
                        name="category"
                        value="{{category}}"
                    />
                    <button id="headerSearchBtn" class="btn btn-danger px-4" type="submit" >
                        Tìm
                    </button>

                </div>
            </form>

            <!-- User -->
            <ul class="navbar-nav ms-lg-4">

                {{#if user}}

                <li class="nav-item dropdown">

                    <a
                        class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                        href="#"
                        role="button"
                        data-bs-toggle="dropdown"
                    >

                        <img
                            src="/img/fita.png"
                            alt="User"
                            width="36"
                            height="36"
                            class="rounded-circle border"
                        >

                        <span> {{user.username}} </span>

                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow">

                        {{#if (eq user.role "admin")}}

                        <li>
                            <a class="dropdown-item" href="/articles/create" >
                                Đăng bài viết
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="/me/stored/articles" >
                                Quản lý bài viết
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        {{/if}}

                        <li>
                            <a class="dropdown-item text-danger" href="/auth/logout" >
                                Đăng xuất
                            </a>
                        </li>

                    </ul>

                </li>

                {{else}}

                <li class="nav-item">
                    <a class="btn btn-outline-light me-2" href="/auth/login" >
                        Đăng nhập
                    </a>
                </li>

                <li class="nav-item">
                    <a class="btn btn-danger" href="/auth/register" >
                        Đăng ký
                    </a>
                </li>

                {{/if}}

            </ul>

        </div>
    </div>
</nav>
<script>
    const searchForm = document.getElementById( 'searchForm' );
    searchForm.addEventListener( 'submit', function () {
        const categoryInput = document.getElementById( 'categoryInput' ); 
        if (!categoryInput.value) { 
            categoryInput.remove();
        }
    });
</script>