<div class="container py-4">
    <!-- Hero -->
    <div class="hero-news text-light mb-5">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="badge bg-danger mb-3">
                    Tin nóng 24h
                </span>
                <h1 class="fw-bold display-5">
                    {{heroTitle}}
                </h1>
                <p class="text-light-emphasis mt-3 mb-0">
                    {{heroDescription}}
                </p>
            </div>
        </div>
    </div>
    <!-- Top viewed -->
    {{#unless search}}
    <div class="mb-5">
        <div class="d-flex align-items-center mb-4">
            <h2 class="fw-bold mb-0">
                🔥 Được xem nhiều nhất
            </h2>
        </div>
        <div class="row g-3">
            {{#each topViewedArticles}}
            <div class="col-md-6 col-lg-4">
                <div class="card news-card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge bg-danger">
                                {{getCategoryName this.category}}
                            </span>
                            <span class="badge bg-dark">
                                👁 {{this.views}} lượt xem
                            </span>
                        </div>
                        <h5 class="fw-bold article-title">
                            <a href="/articles/{{this.slug}}" class="text-decoration-none text-dark">
                                {{this.name}}
                            </a>
                        </h5>
                        <p class="text-muted small mb-3 article-description">
                            {{this.description}}
                        </p>
                        <a href="/articles/{{this.slug}}" class="btn btn-sm btn-outline-danger rounded-pill">
                            Xem bài viết
                        </a>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
    {{/unless}}

    <!-- Section title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                {{#if search}}
                    Kết quả phù hợp
                {{else}}
                    Tin tức mới nhất
                {{/if}}
            </h2>
            <p class="text-muted mb-0">
                Có {{totalArticles}} bài viết
            </p>
        </div>
    </div>

    <!-- News list -->
    <div class="row g-4">
        {{#each articles}}
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <a href="/articles/{{this.slug}}">
                    <img class="card-img-top news-thumbnail"
                        src="{{#if this.image}}{{this.image}}{{else}}/img/default-news.jpg{{/if}}"
                        alt="{{this.name}}"
                    >

                </a>
                <div class="card-body d-flex flex-column">
                <span class="badge bg-danger align-self-start mb-2" >
                    {{getCategoryName this.category}}
                </span>
                    <a href="/articles/{{this.slug}}" class="text-decoration-none text-dark">
                        <h5 class="fw-bold card-title">
                            {{this.name}}
                        </h5>
                    </a>
                    <p class="text-muted card-text flex-grow-1">
                        {{this.description}}
                    </p>
                    <a href="/articles/{{this.slug}}" class="btn btn-outline-danger rounded-pill">
                        Đọc bài viết
                    </a>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{#if showPagination}}

    <nav class="mt-5">

        <ul class="pagination justify-content-center">

            {{#if pagination.hasPrev}}

            <li class="page-item">
                <a
                    class="page-link"
                    href="/?{{searchQuery}}{{categoryQuery}}page={{pagination.prevPage}}"
                >
                    &laquo;
                </a>
            </li>

            {{/if}}

            {{#each pagination.pages}}

            <li class="page-item {{#if (eq this ../pagination.page)}}active{{/if}}">

                <a
                    class="page-link"
                    href="/?{{../searchQuery}}{{../categoryQuery}}page={{this}}"
                >
                    {{this}}
                </a>

            </li>

            {{/each}}

            {{#if pagination.hasNext}}

            <li class="page-item">

                <a
                    class="page-link"
                    href="/?{{searchQuery}}{{categoryQuery}}page={{pagination.nextPage}}"
                >
                    &raquo;
                </a>

            </li>

            {{/if}}

        </ul>

    </nav>

    {{/if}}
    <!-- Empty state -->
    {{#unless totalArticles}}
    <div class="text-center py-5">

        <div
            class="mx-auto mb-4 d-flex align-items-center justify-content-center rounded-circle bg-light shadow-sm"
            style="
                width: 100px;
                height: 100px;
                font-size: 42px;
            "
        >
            <div class="empty-icon mb-4" >
                <i class="bi bi-search"></i>
            </div>
        </div>

        <h3 class="fw-bold mb-3">
            Không tìm thấy bài viết phù hợp
        </h3>

        <p class="text-muted mb-4">
            Thử từ khóa khác hoặc quay lại trang chủ để xem các bài viết mới nhất.
        </p>

        <a
            href="/"
            class="btn btn-danger rounded-pill px-4"
        >
            Xem tất cả bài viết
        </a>

    </div>
    {{/unless}}
</div>