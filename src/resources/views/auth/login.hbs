<div class="container mt-4">

    <h2>Đăng nhập</h2>

    <form method="POST" action="/auth/login">

        <div class="mb-3">
            <label>Email</label>

            <input
                type="email"
                name="email"
                class="form-control"
                required
            >
        </div>

        <div class="mb-3">
            <label>Mật khẩu</label>

            <input
                type="password"
                name="password"
                class="form-control"
                required
            >
        </div>

        <button
            type="submit"
            class="btn btn-primary"
        >
            Đăng nhập
        </button>

    </form>

</div>